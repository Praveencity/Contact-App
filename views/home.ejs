<%- include('partials/header') %>
<link rel="stylesheet" href="/css/home.css">
<%- include('partials/navbar') %>

<main class="page-shell">
  <div class="panel home-panel">
    <div class="home-header">
      <h1 class="home-title">All Contacts</h1>
      <a href="/addContact" class="btn btn-add">+ Add New</a>
    </div>

    <div class="table-container">
      <table class="contact-table">
        <thead>
          <tr>
            <th>#</th>
            <th>First Name</th>
            <th>Last Name</th>
            <th>Email</th>
            <th>Phone</th>
            <th class="center">Actions</th>
          </tr>
        </thead>
        <tbody>
        <% if(contacts.length > 0) { %>
            <% contacts.forEach((contact, index) => { %>
            <tr class="<%= index % 2 === 0 ? 'row-extruded' : 'row-inset' %>">
                <td><%= index + 1 %></td>
                <td class="primary-text"><%= contact.firstName %></td>
                <td><%= contact.lastName %></td>
                <td class="text-soft"><%= contact.email%></td>
                <td class="text-soft"><%= contact.phone %></td>
                <td>
                  <div class="actions action-icons">
                      <a href="/contacts/<%= contact._id %>" class="btn btn-icon" style="color: teal;" title="View">👁</a>
                      <a href="/contacts/<%= contact._id %>/edit" class="btn btn-icon" style="color: #007bff;" title="Edit">✎</a>
                      <button class="btn btn-icon" style="color: #dc3545;" title="Delete">✕</button>
                  </div>
                </td>
            </tr>
            <% }) %>
        <% } else { %>
            <tr>
                <td colspan="6" style="text-align: center; padding: 40px;">No contacts found.</td>
            </tr>
        <% } %>
        </tbody>
      </table>
    </div>
  </div>
</main>

<%- include('partials/footer') %>