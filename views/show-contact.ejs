<%- include('partials/header') %>
<link rel="stylesheet" href="/css/show-contact.css">
<%- include('partials/navbar') %>

<main class="page-shell">
  <div class="contact-card">
    <h2>Contact Details</h2>
    
    <div class="contact-details">
      <div class="form-group">
        <label>First Name</label>
        <div class="detail-value"><%= user.firstName  %></div>
      </div>

      <div class="form-group">
        <label>Last Name</label>
        <div class="detail-value"><%= user.lastName  %></div>
      </div>

      <div class="form-group">
        <label>Email</label>
        <div class="detail-value"><%= user.email  %></div>
      </div>

      <div class="form-group">
        <label>Phone</label>
        <div class="detail-value"><%= user.phone  %></div>
      </div>

      <div class="action-buttons">
        <a href="/" class="btn">Back</a>
        <a href="/contact/update/<%= user._id%>" class="btn">Edit</a>
        <a href="/contact/delete/<%= user._id%>" class="btn btn-delete">Delete</a>
      </div>
    </div>
  </div>
</main>

<%- include('partials/footer') %>